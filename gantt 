<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>MIC Branch Gantt - CSV Version</title>
  <link rel="stylesheet" href="https://unpkg.com/frappe-gantt/dist/frappe-gantt.css">
  <style>
    body { font-family: Arial; margin: 20px; }
    #gantt { overflow-x: scroll; margin-top: 20px; }
    select, input { margin: 5px 0; }
  </style>
</head>
<body>

<h2>MIC Branch Gantt (CSV)</h2>

<p>Select your CSV file:</p>
<input type="file" id="fileInput" accept=".csv" />
<div id="gantt"></div>

<script src="https://unpkg.com/frappe-gantt/dist/frappe-gantt.min.js"></script>
<script>
document.getElementById('fileInput').addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(event) {
        const text = event.target.result;
        const rows = text.split(/\r?\n/).filter(r => r.trim() !== '');
        if (rows.length < 2) {
            alert("CSV appears empty or invalid.");
            return;
        }

        // Parse CSV headers
        const headers = rows[0].split(',').map(h => h.trim());
        const dataRows = rows.slice(1);

        const json = dataRows.map(r => {
            const cols = r.split(',');
            const obj = {};
            headers.forEach((h, i) => obj[h] = cols[i]);
            return obj;
        });

        // Build tasks
        const tasks = [];
        const projectRows = {};
        let rowCounter = 0;

        function parseDate(str) {
            if (!str) return new Date();
            // handle mon 12/05/26
            const parts = str.split(' ');
            if (parts.length < 2) return new Date(str);
            const [day, month, year] = parts[1].split('/');
            return new Date(`20${year}-${month}-${day}`);
        }

        json.forEach((row, i) => {
            const project = row['Project'] || 'No Project';
            if (!(project in projectRows)) projectRows[project] = rowCounter++;

            const start = parseDate(row['Start Date']);
            const duration = parseInt(row['Duration']) || 1;
            const end = new Date(start);
            end.setDate(end.getDate() + duration);

            tasks.push({
                id: `task${i}`,
                name: row['Task'] || `Task ${i+1}`,
                start: start.toISOString().split('T')[0],
                end: end.toISOString().split('T')[0],
                project: project,
                progress: 0,
                custom_class: `project${projectRows[project]}`
            });
        });

        // inject simple colors per project
        const style = document.createElement('style');
        Object.keys(projectRows).forEach((proj, idx) => {
            style.innerHTML += `.project${idx} .bar { fill: hsl(${idx*50 % 360}, 70%, 60%) !important; }\n`;
        });
        document.head.appendChild(style);

        // clear previous Gantt
        document.getElementById('gantt').innerHTML = '';
        new Gantt("#gantt", tasks, {
            view_mode: 'Day',
            custom_popup_html: task => `<b>${task.name}</b><br>Project: ${task.project}`
        });
    };
    reader.readAsText(file);
});
</script>

</body>
</html>